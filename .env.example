# Copy to `.env`; no real secrets here.
# At local startup, keys from `.env` are applied only if not already set in the process environment (system wins).

OPENAI_API_KEY=
BRAVE_API_KEY=
DISCOVERY_LLM_ENABLED=false
DISCOVERY_SOURCE=vk
DISCOVERY_DEFAULT_LIMIT=10
DISCOVERY_QUALIFICATION_ENABLED=false
DISCOVERY_QUALIFICATION_MIN_CONFIDENCE=0.45
